<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="smart_invoice_search_view" model="ir.ui.view">
        <field name="name">smart.invoice.search</field>
        <field name="model">smart.invoice</field>
        <field name="arch" type="xml">
            <search string="Smart Invoices">
                <field name="supplier_name"/>
                <field name="invoice_number"/>
                <filter name="pending" string="Pending" domain="[('status', '=', 'pending')]"/>
                <filter name="extracted" string="Extracted" domain="[('status', '=', 'extracted')]"/>
                <filter name="validated" string="Validated" domain="[('status', '=', 'validated')]"/>
                <filter name="rejected" string="Rejected" domain="[('status', '=', 'rejected')]"/>
                <separator/>
                <filter name="low_confidence" string="Low Confidence" domain="[('confidence', '&lt;', 0.7)]"/>
                <separator/>
                <filter name="gmail" string="Gmail" domain="[('source', '=', 'gmail')]"/>
                <filter name="outlook" string="Outlook" domain="[('source', '=', 'outlook')]"/>
                <group>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_supplier" string="Supplier" context="{'group_by': 'supplier_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="smart_invoice_kanban_view" model="ir.ui.view">
        <field name="name">smart.invoice.kanban</field>
        <field name="model">smart.invoice</field>
        <field name="arch" type="xml">
            <kanban class="o_sb_kanban" default_group_by="status" group_create="false" quick_create="false">
                <field name="status"/>
                <field name="confidence"/>
                <field name="total_ttc"/>
                <field name="currency_code"/>
                <field name="invoice_date"/>
                <field name="move_id"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong class="text-truncate" style="max-width:100%">
                                <field name="invoice_number"/>
                            </strong>
                        </div>
                        <div class="text-muted small text-truncate">
                            <i class="fa fa-building-o me-1" title="Supplier"/>
                            <field name="supplier_name"/>
                        </div>
                        <hr class="my-1"/>
                        <div class="d-flex justify-content-between small">
                            <span><i class="fa fa-calendar-o me-1" title="Date"/><field name="invoice_date"/></span>
                            <strong><field name="total_ttc"/> <field name="currency_code"/></strong>
                        </div>
                        <div class="small mt-1">
                            Confidence:
                            <span t-attf-class="fw-bold {{ record.confidence.raw_value &lt; 0.7 ? 'text-danger' : 'text-success' }}">
                                <field name="confidence"/>
                            </span>
                        </div>
                        <div t-if="record.move_id.raw_value" class="mt-1 small">
                            <span class="badge bg-info text-white">Bill #<field name="move_id"/></span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="smart_invoice_list_view" model="ir.ui.view">
        <field name="name">smart.invoice.list</field>
        <field name="model">smart.invoice</field>
        <field name="arch" type="xml">
            <list decoration-danger="confidence &lt; 0.4 and status in ('pending', 'extracted')"
                  decoration-warning="confidence &lt; 0.7 and confidence &gt;= 0.4 and status in ('pending', 'extracted')"
                  decoration-success="status == 'validated'"
                  decoration-muted="status == 'rejected'">
                <field name="invoice_number"/>
                <field name="supplier_name"/>
                <field name="invoice_date"/>
                <field name="total_ttc"/>
                <field name="currency_code" string="Currency"/>
                <field name="confidence"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'validated'"
                    decoration-info="status == 'extracted'"
                    decoration-warning="status == 'pending'"
                    decoration-danger="status == 'rejected'"/>
                <field name="file_name" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="smart_invoice_form_view" model="ir.ui.view">
        <field name="name">smart.invoice.form</field>
        <field name="model">smart.invoice</field>
        <field name="arch" type="xml">
            <form string="Smart Invoice">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="pending,extracted,validated"/>
                </header>
                <sheet>
                    <group>
                        <field name="source"/>
                        <field name="sender_email"/>
                        <field name="received_at"/>
                        <field name="file_name"/>
                        <field name="confidence" widget="progressbar"/>
                        <field name="move_id" invisible="not move_id"/>
                    </group>

                    <field name="extracted_error" invisible="not extracted_error" widget="text"
                        class="text-danger"/>

                    <div invisible="status != 'pending'" class="alert alert-info" role="alert">
                        This invoice has been received but not yet extracted. Data will appear here once the extraction pipeline processes it.
                    </div>

                    <div invisible="status == 'pending'" class="o_sb_side_by_side">
                        <div class="o_sb_img_col">
                            <div class="o_sb_col_title">Invoice Preview</div>
                            <field name="invoice_file" widget="pdf_viewer" nolabel="1" invisible="not is_pdf"/>
                            <field name="invoice_file" widget="image" nolabel="1" invisible="is_pdf"/>
                        </div>
                        <div class="o_sb_fields_col">
                            <div class="o_sb_col_title">Invoice Details</div>
                            <group>
                                <field name="supplier_name" string="Supplier"/>
                                <field name="supplier_street" string="Address"/>
                                <field name="supplier_country" string="Country"/>
                                <field name="invoice_number" string="Invoice #"/>
                                <field name="invoice_date" string="Date"/>
                                <field name="currency_code" string="Currency"/>
                                <field name="total_ht" string="Total HT"/>
                                <field name="vat_amount" string="VAT"/>
                                <field name="total_ttc" string="Total TTC"/>
                            </group>
                            <field name="line_ids" string="Line Items">
                                <list editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="unit_price" string="Unit Price"/>
                                    <field name="total_line" string="Total"/>
                                    <field name="item_type" string="Type"/>
                                </list>
                            </field>
                        </div>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="smart_invoice_action" model="ir.actions.act_window">
        <field name="name">Smart Invoices</field>
        <field name="res_model">smart.invoice</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_extracted': 1}</field>
    </record>

    <menuitem id="smart_billing_menu_root"
        name="Smart Billing"
        sequence="90"/>

    <menuitem id="smart_billing_menu_invoices"
        name="Invoices"
        parent="smart_billing_menu_root"
        action="smart_invoice_action"
        sequence="10"/>

</odoo>
